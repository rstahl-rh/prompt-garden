#!/usr/bin/env python3
import csv
import sys
from collections import defaultdict


def main():
    if len(sys.argv) != 2:
        print("Usage: python summarize_csv.py <csv_filename>", file=sys.stderr)
        sys.exit(1)

    csv_filename = sys.argv[1]

    # Dictionary to store counts for each machine type
    # Format: {machine_type: {'total': count, 'free': count, 'assigned': count, 'broken': count}}
    machine_stats = defaultdict(lambda: {'total': 0, 'free': 0, 'assigned': 0, 'broken': 0})

    # Read and process the CSV file
    with open(csv_filename, 'r') as csvfile:
        reader = csv.reader(csvfile)
        for row in reader:
            if len(row) < 3:
                continue

            machine_name = row[0]
            assignee = row[1]
            machine_type = row[2]

            # Update total count
            machine_stats[machine_type]['total'] += 1

            # Categorize based on assignee
            if assignee == 'hwbroken':
                machine_stats[machine_type]['broken'] += 1
            elif assignee.strip() == '':
                machine_stats[machine_type]['free'] += 1
            else:
                machine_stats[machine_type]['assigned'] += 1

    # Generate markdown output
    with open('summarized.md', 'w') as mdfile:
        # Write table header
        mdfile.write("| Machine Type | Machine Count | Free | Assigned | BROKEN |\n")
        mdfile.write("|--------------|---------------|------|----------|--------|\n")

        # Write table rows sorted by machine type
        for machine_type in sorted(machine_stats.keys()):
            stats = machine_stats[machine_type]
            mdfile.write(f"| {machine_type} | {stats['total']} | {stats['free']} | {stats['assigned']} | {stats['broken']} |\n")


if __name__ == '__main__':
    main()
